{
  "expo": {
    "name": "CollegePG",
    "slug": "collegepg",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#D97706",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.collegepg.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#D97706"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
